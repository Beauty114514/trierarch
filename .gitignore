# =============================================================================
# Trierarch monorepo — combined ignores (formerly per-module .gitignore)
# Note: trierarch-wayland/wayland/build-android/.gitignore is Meson-autogenerated;
#       do not remove that file.
# =============================================================================

# --- Android / Gradle / Kotlin (trierarch-app) ---
.gradle/
.kotlin/
*.iml
local.properties
**/local.properties
build/
**/build/
app/build
.externalNativeBuild/
.cxx/
captures/
.idea/
.cursor/
# Aggregated native build outputs copied into app module for packaging
trierarch-app/app/src/main/jniLibs/
# Pulse prefix synced by trierarch-audio/build-android/build-pulse-android.sh
trierarch-app/app/src/main/assets/pulse/

# --- trierarch-audio (PulseAudio port/build) ---
# Upstream clones + build outputs live here; keep only our scripts/patches/modules tracked.
trierarch-audio/third_party/
trierarch-audio/out/

# --- trierarch-virgl (upstream sources + local NDK out; track README and build-android/*.sh only) ---
trierarch-virgl/build-src/
trierarch-virgl/out/

# Release APK signing secrets (see trierarch-app/keystore.properties.example)
trierarch-app/keystore.properties
trierarch-app/*.jks
trierarch-app/*.keystore

# --- Rust (trierarch-native) ---
**/target/

# --- trierarch-proot (C / NDK build) ---
trierarch-proot/**/*.o
trierarch-proot/**/*.d
trierarch-proot/**/*.res
*~
trierarch-proot/src/build.h
trierarch-proot/src/loader/loader
trierarch-proot/src/loader/loader-m32
trierarch-proot/src/loader/loader-info.c
trierarch-proot/src/proot
trierarch-proot/build-android/
trierarch-proot/build/
trierarch-proot/**/*.a
trierarch-proot/**/*.so

# --- trierarch-wayland (ndk-build / prebuilt libs) ---
trierarch-wayland/obj/
trierarch-wayland/out/
trierarch-wayland/libs/arm64-v8a/
!trierarch-wayland/libs/.gitkeep
trierarch-wayland/libffi-install/
trierarch-wayland/libffi-*.tar.gz
trierarch-wayland/build-src/
# Upstream libffi tree (unpack from libffi-*.tar.gz for builds; do not commit)
trierarch-wayland/libffi/
trierarch-wayland/**/*.o
trierarch-wayland/**/*.a
trierarch-wayland/**/*.so
trierarch-wayland/**/.git/

# --- trierarch-wayland/wayland (vendored upstream; patterns from wayland/.gitignore) ---
trierarch-wayland/**/*.announce
trierarch-wayland/**/*.sig
trierarch-wayland/**/*.swp
trierarch-wayland/**/cscope.out
trierarch-wayland/**/ctags
trierarch-wayland/**/*.log
trierarch-wayland/wayland/**/*.tar.xz
trierarch-wayland/wayland/src/*.dtd.embed
trierarch-wayland/wayland/src/wayland-version.h
trierarch-wayland/wayland/protocol/wayland.html
trierarch-wayland/wayland/protocol/.wayland.xml.valid
trierarch-wayland/wayland/doc/publican/Wayland
trierarch-wayland/wayland/doc/publican/en-US/
trierarch-wayland/wayland/doc/publican/publican-copy.cfg
trierarch-wayland/wayland/doc/doxygen/doxygen_sqlite3.db
trierarch-wayland/wayland/doc/doxygen/html/
trierarch-wayland/wayland/doc/doxygen/wayland.doxygen

# --- Debug / logs ---
logcat*.txt
*.log

# --- OS ---
.DS_Store
Thumbs.db
