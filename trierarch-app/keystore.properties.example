# Copy this file to keystore.properties (DO NOT commit keystore.properties).
# Generate a keystore once, e.g. from trierarch-app/:
#   keytool -genkey -v -keystore release.keystore -alias trierarch -keyalg RSA -keysize 2048 -validity 10000
#
# Paths are relative to the trierarch-app/ directory (same folder as this file).

storeFile=release.keystore
storePassword=change-me
keyAlias=trierarch
keyPassword=change-me
